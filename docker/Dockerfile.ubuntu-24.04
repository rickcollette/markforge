# Build MarkForge .deb for Ubuntu 24.04 (Noble).
# Usage:
#   docker build -f docker/Dockerfile.ubuntu-24.04 -t markforge-build:ubuntu24 .
#   docker create --name mf-u24 markforge-build:ubuntu24
#   docker cp mf-u24:/app/src-tauri/target/release/bundle/deb/. ./dist-packages/ubuntu-24.04/
#   docker rm mf-u24
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Tauri v2 Linux prerequisites + deb packaging tools.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    wget \
    file \
    pkg-config \
    libwebkit2gtk-4.1-dev \
    libgtk-3-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    libxdo-dev \
    libssl-dev \
    patchelf \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 (frontend toolchain).
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Rust (stable, minimal profile).
RUN curl -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# Dependency layers first for docker cache friendliness.
COPY package.json package-lock.json ./
RUN npm ci

COPY . .

RUN npm run tauri build -- --bundles deb

# Artifacts land in /app/src-tauri/target/release/bundle/deb/*.deb
